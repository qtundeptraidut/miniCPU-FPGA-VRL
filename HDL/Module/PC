module PC (
    input clk,
    input rst_n,
    input run_en,
    input pc_inc,
    input pc_reset,
    output reg [7:0] pc_out
);
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n)
            pc_out <= 8'h00;
        else if (pc_reset)
            pc_out <= 8'h00;
        else if (run_en && pc_inc)
            pc_out <= pc_out + 8'h01;
    end
endmodule
